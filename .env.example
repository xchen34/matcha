PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=postgres
# On macOS Homebrew, if socket connection is needed, use:
# DB_HOST=/tmp
FRONTEND_BASE_URL=http://localhost:5173
# Comma-separated allowed origins for CORS.
# Example: CORS_ORIGIN=http://localhost:5173,http://localhost:8080
CORS_ORIGIN=http://localhost:5173
# Comma-separated allowed origins for CSRF checks on unsafe methods.
# Example: CSRF_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
CSRF_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting (all values are optional)
# Global API limiter
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=600
# Auth limiter for register/verify
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
# Stricter limiter for login/reset/forgot/resend
RATE_LIMIT_AUTH_SENSITIVE_WINDOW_MS=900000
RATE_LIMIT_AUTH_SENSITIVE_MAX=8

# SMTP mail configuration
# Dev option: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Optional aliases (also supported by backend):
# ETHEREAL_USER=
# ETHEREAL_PASSWORD=
SMTP_FROM_EMAIL=noreply@matcha.local
